<section class="hero-section">
  <div class="container">
    <div class="row align-items-center hero-row">
      <div class="col-lg-6">
        <p class="eyebrow">Authentic Korean Meal Kits</p>

        <h1 class="hero-title">
          Delivering More Than Food,<br>
          Delivering Authenticity.
        </h1>

        <p class="hero-text">
          Authentic Korean meal kits made with fresh ingredients, delivered to your door.
        </p>

        <a href="/mealkits" class="btn btn-dark hero-btn">
          Explore Meal Kits →
        </a>
      </div>

      <div class="col-lg-6 mt-5 mt-lg-0">
        <div class="hero-image-card">
          <img src="/images/home_Hero.jpg" alt="Korean meal kit" class="hero-image">
        </div>
      </div>
    </div>
  </div>
</section>

<section class="features-section">
  <div class="container">
    <div class="row text-center g-4">
      <div class="col-12 col-md-6 col-lg-3">
        <div class="feature-item">
          <div class="feature-icon">🌿</div>
          <h5>Authentic Ingredients</h5>
          <p>Carefully selected Korean-inspired ingredients for real flavours.</p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="feature-item">
          <div class="feature-icon">📦</div>
          <h5>Easy & Quick</h5>
          <p>Simple ordering and convenient meal kits delivered to your door.</p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="feature-item">
          <div class="feature-icon">👨‍🍳</div>
          <h5>Freshly Prepared</h5>
          <p>Prepared with freshness, quality, and convenience in mind.</p>
        </div>
      </div>

      <div class="col-12 col-md-6 col-lg-3">
        <div class="feature-item">
          <div class="feature-icon">♡</div>
          <h5>Enjoy at Home</h5>
          <p>Experience the taste of Korea from the comfort of your home.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="featured-section">
  <div class="container">
    <div class="section-heading text-center">
      <p class="section-label">Featured</p>
      <h2>Featured Meal Kits</h2>
      <p>Handpicked favourites loved by our customers.</p>
    </div>

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 g-4">
      <% if (typeof featuredMealKits !== 'undefined' && featuredMealKits.length > 0) { %>
        <% featuredMealKits.forEach(featuredMealKit => { %>
          <div class="col">
            <%- include("../mealkits/mealkit", { selectedMealKit: featuredMealKit }) %>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-12 text-center">
          <p>No featured meal kits available.</p>
        </div>
      <% } %>
    </div>

    <div class="text-center mt-5">
      <a href="/mealkits" class="btn btn-outline-dark view-all-btn">
        View All Meal Kits →
      </a>
    </div>
  </div>
</section>