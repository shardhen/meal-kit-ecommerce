<!-- Base structure for log-in html frame from https://bootswatch.com/lux/ modifed by Chanhee Han-->

<div class="container mt-5">
<p class="fw-bold text-center form-text text-dark fs-4">Welcome back!</p>

<form class="border rounded p-4 shadow-sm border-dark">
  <fieldset>
    <div>
      <label for="loginInputEmail" class="form-label mt-4 text-center fs-6">Email address</label>
      <input type="text" class="form-control" id="loginInputEmail" placeholder="Enter email">
    </div>
    <div>
      <label for="loginInputEmail" class="form-label mt-4 text-center fs-6">Password</label>
      <input type="text" class="form-control" id="loginInputEmail" placeholder="Password" autocomplete="off">
    </div>
        <fieldset>
      <legend class="mt-4"></legend>
      <div class="form-check form-switch">
        <input class="form-check-input" type="radio" id="loginCustomer" name="identificationLogIn" checked="">
        <label class="form-check-label" for="loginCustomer">Customer</label>
      </div>
      <div class="form-check form-switch">
        <input class="form-check-input" type="radio" id="loginClerk" name="identificationLogIn">
        <label class="form-check-label" for="loginClerk">Data Clerk</label>
      </div>
    </fieldset>
  </fieldset>

    <button type="submit" class="btn btn-primary text-center mt-4 px-5">Log in</button>

</form>
</div>