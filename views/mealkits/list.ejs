<div class="container mt-5 mb-5 text-center">

    <div class="mb-4">
        <a class="btn btn-dark btn-lg px-5" href="/mealkits" role="button">
            Start Exploring Menu
        </a>

        <% if (user && user.role === "clerk") { %>
            <div class="mt-3">
                <a class="btn btn-dark btn-lg px-5" href="/load-data/mealkits" role="button">
                    Load Meal Kits Data
                </a>
            </div>

                    <div class="mt-3">
                <a class="btn btn-dark btn-lg px-5" href="/mealkits/add">Add Meal Kit</a>
            </div>
        <% } %>
    </div>


    <% if (!mealKits || mealKits.length === 0) { %>

        <div class="py-5 px-4 mb-4 bg-light rounded-3 shadow-sm border border-dark">
            <h1 class="display-4 fw-bold">Your list is empty</h1>
        </div>

    <% } else { %>

        <h1 class="mb-4">Meal Kits List</h1>

        <% mealKits.forEach(function(meal){ %>

    <div class="border p-4 mb-3">
        <h4><%= meal.title %></h4>
        <p><%= meal.description %></p>
        <p>$<%= meal.price %></p>

        <% if (user && user.role === "clerk") { %>
            <a href="/mealkits/edit/<%= meal._id %>" class="btn btn-primary">Edit</a>
            <a href="/mealkits/remove/<%= meal._id %>" class="btn btn-danger">Delete</a>
        <% } %>

        <% if (user && user.role === "customer") { %>
            <a href="/mealkits/add-to-cart/<%= meal._id %>" class="btn btn-success">Add to Cart</a>
        <% } %>

    </div>

<% }) %>

    <% } %>

</div>