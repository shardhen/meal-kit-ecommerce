<% if (selectedMealKit) { %>
  <div class="card meal-card h-100">

    <div class="meal-image-wrap">
      <img
        src="<%= selectedMealKit.imageUrl %>"
        class="card-img-top"
        alt="<%= selectedMealKit.title %>"
      >
    </div>

    <div class="card-body d-flex flex-column">
      <h5 class="meal-title"><%= selectedMealKit.title %></h5>

      <p class="meal-description">
        <%= selectedMealKit.description %>
      </p>

      <div class="meal-meta mb-3">
        <span>Serves <%= selectedMealKit.servings %></span>
        <% if (selectedMealKit.cookingTime) { %>
          <span>•</span>
          <span><%= selectedMealKit.cookingTime %> min</span>
        <% } %>
      </div>

      <div class="mt-auto">
        <p class="meal-price">$<%= Number(selectedMealKit.price).toFixed(2) %></p>

        <% if (typeof user !== 'undefined' && user && user.role === "customer") { %>
          <a href="/add-to-cart/<%= selectedMealKit._id %>" class="btn btn-dark w-100 add-cart-btn">
            Add to Cart
          </a>
        <% } else { %>
          <a href="/log-in" class="btn btn-outline-dark w-100 add-cart-btn">
            Order
          </a>
        <% } %>
      </div>
    </div>

  </div>
<% } else { %>
  <div class="alert alert-warning">
    Information is hidden for this item.
  </div>
<% } %>